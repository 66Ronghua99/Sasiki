{
  "manifest_version": 3,
  "name": "Sasiki Recorder",
  "version": "1.0.0",
  "description": "Record browser actions for automated workflow generation",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Sasiki Recorder",
    "default_popup": "popup.html"
  },
  "icons": {}
}
