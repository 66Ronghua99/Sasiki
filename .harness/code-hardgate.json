{
  "version": "1",
  "artifact_dir": "artifacts/code-gate",
  "commands": {
    "lint": "npm --prefix apps/agent-runtime run lint",
    "test": "cd apps/agent-runtime && node --test scripts/tests/*.test.mjs && npm run test"
  },
  "flaky_policy": {
    "max_retries": 0,
    "allow_retry_success_as_warning": false
  }
}
