{
  "manifest_version": 3,
  "name": "Sasiki Cookie Capture",
  "version": "0.1.0",
  "description": "Capture site cookies into Sasiki without manual JSON export.",
  "permissions": ["cookies", "tabs"],
  "host_permissions": ["https://*.tiktok.com/*", "https://www.tiktok.com/*", "http://127.0.0.1/*"],
  "action": {
    "default_title": "Sasiki Cookie Capture",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  }
}
