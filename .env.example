# LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=anthropic/claude-3-sonnet-20240229
LLM_BASE_URL=https://openrouter.ai/api/v1

# Recording Settings
RECORDINGS_DIR=~/.sasiki/recordings
WORKFLOWS_DIR=~/.sasiki/workflows
MAX_RECORDING_DURATION_MINUTES=60

# Analysis Settings
FRAME_SAMPLE_RATE=1
SIMILARITY_THRESHOLD=0.9
MAX_FRAMES_PER_ANALYSIS=100

# Debug
DEBUG=false
LOG_LEVEL=INFO
