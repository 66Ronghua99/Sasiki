# LLM Configuration
# Preferred (domestic): DashScope compatible endpoint
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Fallback: OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional overrides (if set, they override provider defaults)
# LLM_MODEL=minimax/minimax-m2.5
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Recording Settings
RECORDINGS_DIR=~/.sasiki/recordings
WORKFLOWS_DIR=~/.sasiki/workflows
MAX_RECORDING_DURATION_MINUTES=60

# Analysis Settings
FRAME_SAMPLE_RATE=1
SIMILARITY_THRESHOLD=0.9
MAX_FRAMES_PER_ANALYSIS=100

# Debug
DEBUG=false
LOG_LEVEL=INFO
