# LLM (preferred: domestic OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional fallbacks/overrides
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_API_KEY=override_api_key
# LLM_MODEL=openai/qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MCP runtime
MCP_COMMAND=npx
MCP_ARGS=@playwright/mcp@latest

# Browser/CDP
PLAYWRIGHT_MCP_CDP_ENDPOINT=http://localhost:9222
LAUNCH_CDP=true
CDP_USER_DATA_DIR=~/.sasiki/chrome_profile
CDP_HEADLESS=false
INJECT_COOKIES=true
COOKIES_DIR=~/.sasiki/cookies
PREFER_SYSTEM_BROWSER=true
# CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CDP_STARTUP_TIMEOUT_MS=30000

# Artifacts
RUNTIME_ARTIFACTS_DIR=artifacts/e2e
